{
  "expo": {
    "name": "맞짱 오락실",
    "slug": "tenten-arcade",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "backgroundColor": "#0f1220",
    "splash": {
      "backgroundColor": "#0f1220"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "backgroundColor": "#0f1220"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "QR 코드를 찍어 친구 방에 참가하려면 카메라 권한이 필요해요."
        }
      ]
    ]
  }
}
